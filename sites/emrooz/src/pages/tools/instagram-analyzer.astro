---
import BaseLayout from "../../components/layout/BaseLayout.astro";
---

<BaseLayout title="Instagram Analyzer — emrooz">
  <div class="min-h-screen flex flex-col items-center justify-center px-6 text-center bg-navy">
    <span class="text-5xl mb-4">📸</span>
    <h1 class="font-display text-4xl font-bold text-cream mb-3">Instagram Analyzer</h1>
    <p class="text-cream-muted/60 max-w-md">
      Upload your Instagram follower/following export and see who doesn't follow you back, who you don't follow back, and mutuals — all processed locally in your browser. Coming soon.
    </p>
    <a href="/" class="mt-8 text-gold font-medium hover:text-gold/80 transition-colors">&larr; Back to emrooz</a>
  </div>
</BaseLayout>
